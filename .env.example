# =============================================================================
# Agentic Travel Planner — environment configuration
# Copy this file to `.env` and fill in real values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM provider
# -----------------------------------------------------------------------------
# Preferred provider. Case-insensitive: anthropic | openai | google.
# If the key for the preferred provider is missing, the app falls back to
# whichever provider does have a key set.
LLM_PROVIDER=anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# Real-data APIs
# -----------------------------------------------------------------------------
# Amadeus Self-Service — powers real flight + hotel search.
# Without keys, the tools fall back to mock results / deeplink-only.
FLIGHT_API_KEY=
FLIGHT_API_SECRET=

# Travelpayouts affiliate marker. Required to earn commission on the
# Aviasales / Hotellook / RentalCars deeplinks the agent generates.
# The URLs work without it, you just lose attribution.
TRAVELPAYOUTS_MARKER=
CARS_AFFILIATE_HOST=https://tp.media/r

# -----------------------------------------------------------------------------
# Payment (Stripe Checkout)
# -----------------------------------------------------------------------------
# Mode: test | live | mock
#   test:  real Stripe API in test mode (default for staging/dev)
#   live:  real Stripe API with real money (production)
#   mock:  in-memory only, no network calls (CI / offline dev)
STRIPE_MODE=test
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Web server
# -----------------------------------------------------------------------------
# Used to build success_url / cancel_url for Stripe Checkout.
APP_URL=http://localhost:5000
# Comma-separated list of allowed CORS origins. Wildcard is NOT supported in prod.
ALLOWED_ORIGINS=http://localhost:5000
# Upload + timeout limits.
MAX_UPLOAD_MB=25
REQUEST_TIMEOUT_SECONDS=300
# Per-session memory bookkeeping.
SESSION_TTL_SECONDS=3600
MAX_SESSIONS=1000

# -----------------------------------------------------------------------------
# Agent loop
# -----------------------------------------------------------------------------
MAX_TURNS=10
MAX_LLM_RETRIES=3
MAX_TOOL_RETRIES=3
MAX_MESSAGES=50

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------
# Langfuse traces every agent turn + LLM call. Disabled if keys are missing.
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# -----------------------------------------------------------------------------
# External MCP subprocesses (optional)
# -----------------------------------------------------------------------------
# When GOOGLE_MAPS_API_KEY is set, the @modelcontextprotocol/server-google-maps
# Node subprocess is spawned at app startup and its tools (maps_geocode,
# maps_directions, maps_distance_matrix, maps_places, ...) become available to
# the LLM. Requires Node.js + npx on the host (the subprocess runs via
# `npx -y @modelcontextprotocol/server-google-maps`). Get a key at
# https://console.cloud.google.com/google/maps-apis/credentials — billing must
# be enabled on the project and Geocoding/Directions/Places APIs activated.
GOOGLE_MAPS_API_KEY=
